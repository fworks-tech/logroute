{
  "name": "logroute-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit && eslint src/",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:e2e": "playwright test",
    "generate:api-client": "bash scripts/generate-api-client.sh",
    "api:dev": "cd ../backend && python manage.py runserver 8000",
    "api:migrate": "cd ../backend && python manage.py migrate",
    "api:test": "cd ../backend && pytest"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^3.0.0",
    "@mui/icons-material": "^6.0.0",
    "@mui/material": "^6.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "axios": "^1.7.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "react-joyride": "^3.1.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.12.0",
    "zod": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.11",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "identity-obj-proxy": "^3.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
